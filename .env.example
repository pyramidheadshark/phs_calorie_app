# ── AI ────────────────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_MODEL=google/gemini-3-flash-preview

# ── Telegram ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=123456789:AAF...
TELEGRAM_WEBHOOK_SECRET=your-random-secret
APP_URL=https://your-subdomain.tuna.am

# ── Tunnel ────────────────────────────────────────────────────────────────────
TUNA_TOKEN=tt_...
TUNA_SUBDOMAIN=your-subdomain      # только часть до .ru.tuna.am

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_URL=postgresql+asyncpg://calorie:secret@postgres:5432/calorie_dev
POSTGRES_SYNC_URL=postgresql+psycopg2://calorie:secret@postgres:5432/calorie_dev

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── App ───────────────────────────────────────────────────────────────────────
APP_PORT=8001
DEBUG=false
